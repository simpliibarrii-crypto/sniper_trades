{
  "manifest_version": 3,
  "name": "Raven Sniper Trades Bridge",
  "version": "7.0.0",
  "description": "Read-only localhost market intelligence, evidence, and signal status from Raven Sniper Trades.",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Raven Sniper Trades",
    "default_popup": "popup.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  }
}
